generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for local development – zero setup, just a file.
  // The connection URL is now configured in prisma.config.ts (Prisma 7+).
  // Change provider to "postgresql" when deploying to production.
  provider = "sqlite"
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  brandSettings BrandSettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BrandSettings {
  id       String    @id @default(cuid())
  userId   String    @unique
  name     String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  brandId     String
  name        String
  description String
  price       Float?
  imageUrl    String?
  metadata    String?  // JSON stored as text in SQLite
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand BrandSettings @relation(fields: [brandId], references: [id], onDelete: Cascade)
}
